# URL eines lokalen Inferenz-Endpoints (z. B. Hermes-Mock via `npm run mock:hermes`).
# Wenn nicht gesetzt, liefert /api/local-model eine Mock-Antwort.
LOCAL_MODEL_URL=http://localhost:8080/predict

# Pfad zur Ollama-CLI für die /api/ollama-Route (Standard-Modell: qwen2.5-coder).
OLLAMA_PATH=C:\\Users\\<user>\\AppData\\Local\\Programs\\Ollama\\ollama.exe
